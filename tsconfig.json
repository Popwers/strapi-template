{
	"extends": "@strapi/typescript-utils/tsconfigs/server",
	"compilerOptions": {
		"outDir": "dist",
		"rootDir": ".",
		"lib": ["ES2022"],
		"module": "Node16",
		"moduleResolution": "Node16",
		"strictNullChecks": true,
		"types": ["node", "bun"]
	},
	"include": ["./", "./**/*.ts", "./**/*.js", "src/**/*.json"],
	"exclude": [
		"node_modules/",
		"build/",
		"dist/",
		".cache/",
		".tmp/",
		"src/admin/",
		"src/plugins/**",
		"types/generated/**",
		"vite.config.ts"
	]
}
