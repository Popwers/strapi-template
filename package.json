{
  "name": "strapi-template",
  "private": true,
  "version": "0.1.0",
  "description": "Strapi CMS",
  "scripts": {
    "dev": "strapi develop",
    "start": "strapi start",
    "build": "strapi build",
    "strapi": "strapi",
    "test": "bun test",
    "gen:types": "strapi ts:generate-types --debug",
    "upgrade": "npx @strapi/upgrade latest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.969.0",
    "@strapi/plugin-sentry": "5.48.0",
    "@strapi/plugin-users-permissions": "5.48.0",
    "@strapi/provider-email-nodemailer": "5.48.0",
    "@strapi/strapi": "5.48.0",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.0.0",
    "sharp": "^0.34.5",
    "styled-components": "^6.3.6",
    "typescript": "^5"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^25",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "semantic-release": "^25.0.2",
    "vite-plus": "^0.1.22"
  },
  "author": {
    "name": "Lionel Bataille"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=6.0.0"
  },
  "strapi": {
    "uuid": ""
  },
  "release": {
    "branch": "main",
    "repositoryUrl": "https://github.com/your-repo",
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/git",
      [
        "@semantic-release/github",
        {
          "successComment": false
        }
      ]
    ]
  },
  "packageManager": "npm@11.16.0"
}
